# ============================================================
# YouTube AI Agent — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your keys below
# 3. Never commit .env to Git
# ============================================================

# ── LLM: Groq (free at console.groq.com) ─────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Research: Tavily (free at app.tavily.com) ─────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Stock Media: Pexels (free at pexels.com/api) ─────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ── YouTube API (Google Cloud Console) ───────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secrets.json
YOUTUBE_CREDENTIALS_FILE=config/youtube_credentials.json

# ── Video Settings ────────────────────────────────────────────────────────────
SHORTS_DURATION_SECONDS=58
LONG_VIDEO_DURATION_SECONDS=480
VIDEO_RESOLUTION_SHORTS=1080x1920
VIDEO_RESOLUTION_LONG=1920x1080

# ── TTS Settings ──────────────────────────────────────────────────────────────
KOKORO_VOICE=af_heart
KOKORO_SPEED=1.1

# ── Audio ─────────────────────────────────────────────────────────────────────
MUSIC_VOLUME=0.15

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
